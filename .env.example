# CobroDetector — Environment Variables
# Copiar a .env y completar con valores reales
# Ver cobro-detector/.env.example para descripciones detalladas

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Groq
GROQ_API_KEY=gsk_...

# Upstash Redis
UPSTASH_REDIS_URL=https://xxxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=xxx

# Resend (notificaciones)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# Microservicios URLs (Docker compose — apuntan al nombre del servicio)
ANALYSIS_SERVICE_URL=http://analysis-svc:3001
PAYMENT_SERVICE_URL=http://payment-svc:3002
NOTIFICATION_SERVICE_URL=http://notification-svc:3003
ADMIN_SERVICE_URL=http://admin-svc:3005
